# SPA-Routing: Alle Anfragen, die keine Datei oder kein Verzeichnis sind,
# werden auf index.html umgeschrieben, damit React Router übernehmen kann.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Direkt auf HTTPS umleiten (optional, IONOS liefert ohnehin per Default)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Echte Dateien und Verzeichnisse unverändert durchlassen
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alles andere auf die SPA (index.html) umschreiben
  RewriteRule ^ index.html [L]
</IfModule>

# Gzip/Brotli-Kompression für Text-Assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Aggressives Caching für gehashte Vite-Assets, kein Caching für index.html
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Sicherheits-Header
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

ErrorDocument 404 /index.html
